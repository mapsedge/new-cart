Options -Indexes
DirectoryIndex index.php

RewriteEngine On

# Map public admin path to admin/index.php
RewriteRule ^Cc7DZbWFVDSh/?$ /admin/index.php [L,QSA]
RewriteRule ^Cc7DZbWFVDSh/(.*)$ /admin/index.php [L,QSA]

# Serve sitemap.xml through PHP (auto-generated)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^sitemap\.xml$ /index.php [L,QSA]

# Route everything else through index.php (skip real files/dirs)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php [L,QSA]
